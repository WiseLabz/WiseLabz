{
  "name": "wiselabz-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "orval --config ./orval.config.ts",
    "dev": "vite",
    "prebuild": "orval --config ./orval.config.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "gen:api": "orval --config ./orval.config.ts",
    "gen:api:watch": "orval --config ./orval.config.ts --watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\""
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/inter-tight": "^5.2.7",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "@tanstack/react-query": "^5.101.1",
    "@types/diff": "^7.0.2",
    "axios": "^1.18.1",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "i18next": "^26.3.2",
    "motion": "^12.42.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.2",
    "react-grid-layout": "^2.2.3",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-grid-layout": "^1.3.6",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "msw": "^2.14.6",
    "orval": "^8.19.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.0",
    "vite": "^7.2.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
