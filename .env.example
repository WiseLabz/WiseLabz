# WiseLabz — environment configuration reference
#
# Copy this file to `.env` and fill in real values before running either
# compose stack:
#   cp .env.example .env
#   docker compose up -d                              # Postgres stack
#   docker compose -f docker-compose.sqlite.yml up -d  # SQLite stack
#
# `.env` is gitignored — never commit real secrets.

# -----------------------------------------------------------------------
# REQUIRED — app refuses to start without these
# -----------------------------------------------------------------------

# JWT signing secret. REQUIRED. Minimum 32 characters. The server hard-fails
# at startup if this is missing or shorter than 32 chars — there is no
# default and it is never auto-generated for you.
# Generate one with:
#   openssl rand -base64 48
WISELABZ_AUTH_SECRET=

# Password for the initial "admin" operator-role user. REQUIRED only on
# first boot (when no users exist yet) — the server hard-fails at startup
# in that case if this is unset. It is hashed with bcrypt and used once to
# bootstrap the admin account; ignored on every subsequent boot once a user
# already exists. Safe to leave set in .env afterward (it just won't be
# used again), but consider clearing it once the admin account is created.
WISELABZ_ADMIN_PASSWORD=

# -----------------------------------------------------------------------
# Postgres connection (used by docker-compose.yml only)
# -----------------------------------------------------------------------
# These feed both the `postgres` service's own startup config and the
# WISELABZ_DB_DSN that docker-compose.yml builds for the `app` service —
# keep all three in sync if you change them.

POSTGRES_USER=wiselabz
POSTGRES_PASSWORD=changeme
POSTGRES_DB=wiselabz

# -----------------------------------------------------------------------
# Database driver overrides (optional)
# -----------------------------------------------------------------------
# Not needed for either reference stack as shipped:
#   - docker-compose.yml already sets WISELABZ_DB_DRIVER=postgres and
#     builds WISELABZ_DB_DSN from the POSTGRES_* vars above.
#   - docker-compose.sqlite.yml relies on the app's built-in default
#     (driver "sqlite", DSN "file:/data/wiselabz.db?cache=shared").
# Uncomment only if you need to override the defaults directly (e.g. a
# custom sqlite path, or pointing at an external/managed postgres instance
# instead of the bundled `postgres` service).
# WISELABZ_DB_DRIVER=sqlite
# WISELABZ_DB_DSN=file:/data/wiselabz.db?cache=shared

# -----------------------------------------------------------------------
# Server (optional — defaults are sane for container use)
# -----------------------------------------------------------------------

# Listen host/port. Default is 0.0.0.0:8080, which is already correct for
# running inside a container with the published port mapping in the
# compose files. Usually no need to set these.
# WISELABZ_SERVER_HOST=0.0.0.0
# WISELABZ_SERVER_PORT=8080

# CORS origin — set this to the public URL your reverse proxy exposes the
# app on (e.g. https://wiselabz.example.com), if it differs from the
# default. Required if you access the app through a different origin than
# the bare host:port (typical once a reverse proxy with a real domain is in
# front of it).
# WISELABZ_SERVER_ORIGIN=https://wiselabz.example.com

# NOTE: WISELABZ_SERVER_EMBED is intentionally NOT set here — the Docker
# image already sets it to "true" via an image-level ENV, so it does not
# need to (and should not) be overridden in this file.

# -----------------------------------------------------------------------
# AI features (optional — omit entirely to leave AI disabled, or for
# self-hosted/Ollama setups that don't need an API key)
# -----------------------------------------------------------------------

# WISELABZ_AI_ENABLED=false
# WISELABZ_AI_PROVIDER=openai
# WISELABZ_AI_BASE_URL=
# WISELABZ_AI_API_KEY=

# -----------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------

# WISELABZ_LOG_LEVEL=info
# WISELABZ_LOG_FORMAT=json
